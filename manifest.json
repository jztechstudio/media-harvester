{
  "manifest_version": 3,
  "name": "All Video Downloader",
  "version": "1.0",
  "description": "Download videos from Facebook, YouTube, Instagram",

  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "tabs"
  ],

  "host_permissions": [
    "https://www.facebook.com/*",
    "https://www.youtube.com/*",
    "https://www.instagram.com/*",
    "https://fb.watch/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.youtube.com/*",
        "https://www.instagram.com/*",
        "https://fb.watch/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  }
}
